# Root convenience env file (optional)
# You can also keep env files per app:
# - backend/.env
# - frontend/.env

# Backend
SERVER_PORT=8080
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
MYSQL_URL=jdbc:mysql://localhost:3306/phishguard_ai?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
MYSQL_USER=root
MYSQL_PASSWORD=password
JPA_DDL_AUTO=update
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_SERVICE_ACCOUNT_PATH=C:\\path\\to\\firebase-service-account.json
GEMINI_API_KEY=your_gemini_api_key
SAFE_BROWSING_API_KEY=your_safe_browsing_api_key
URL_MODEL_WEIGHTS_PATH=backend\\url-model-weights.json
TEXT_MODEL_WEIGHTS_PATH=backend\\text-model-weights.json
FILE_MODEL_WEIGHTS_PATH=backend\\file-model-weights.json
LOCAL_LLM_ENABLED=false
LOCAL_LLM_BASE_URL=http://localhost:8001
LOCAL_LLM_ANALYZE_PATH=/analyze
LOCAL_LLM_TIMEOUT_MS=60000
SANDBOX_SCANNER_ENABLED=false
SANDBOX_SCANNER_BASE_URL=http://localhost:8002
SANDBOX_SCANNER_ANALYZE_PATH=/analyze
INCOMING_MAIL_ENABLED=false
INCOMING_MAIL_USER_ID=demo
INCOMING_MAIL_HOST=imap.gmail.com
INCOMING_MAIL_PORT=993
INCOMING_MAIL_PROTOCOL=imaps
INCOMING_MAIL_USERNAME=your_mailbox@example.com
INCOMING_MAIL_PASSWORD=your_app_password
INCOMING_MAIL_FOLDER=INBOX
INCOMING_MAIL_POLL_INTERVAL_MS=30000
INCOMING_MAIL_MAX_MESSAGES=10
INCOMING_MAIL_MARK_SEEN=true
WINDOWS_NOTIFICATIONS_ENABLED=false
WINDOWS_NOTIFICATIONS_USER_ID=demo
WINDOWS_NOTIFICATIONS_DB_PATH=
WINDOWS_NOTIFICATIONS_POLL_INTERVAL_MS=5000
WINDOWS_NOTIFICATIONS_ALLOWED_APPS=5319275A.WhatsAppDesktop_cv1g1gvanyjgm!App
WINDOWS_NOTIFICATIONS_IGNORED_PAYLOAD_TYPES=badge,tile

# Frontend (Vite uses VITE_ prefix)
VITE_API_BASE_URL=http://localhost:8080
VITE_FIREBASE_API_KEY=your_firebase_web_api_key
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id
VITE_FIREBASE_STORAGE_BUCKET=your-project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=1234567890
VITE_FIREBASE_APP_ID=1:1234567890:web:abc123

